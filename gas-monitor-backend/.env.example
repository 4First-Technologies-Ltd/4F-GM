# PostgreSQL connection string
# Local dev:
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gas_monitor_db"
# Production (Railway Postgres): if the backend service also runs on Railway,
# add a Postgres plugin to the project and reference its connection string as
# DATABASE_URL="${{Postgres.DATABASE_URL}}" in the backend service's variables
# instead of hardcoding it. If the DB is external to Railway, paste the
# "Postgres Connection URL" from the Postgres plugin's Connect tab directly.

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# Paystack — get keys from https://dashboard.paystack.com/#/settings/developers
# Use sk_test_... in development, sk_live_... in production
PAYSTACK_SECRET_KEY="sk_test_YOUR_SECRET_KEY_HERE"
