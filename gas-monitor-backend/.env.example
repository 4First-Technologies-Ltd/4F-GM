# Server
PORT=9000
NODE_ENV=development
# Comma-separated list of allowed browser origins (web + admin frontends, plus local dev ports).
# Production: https://4fgmonitor.com,https://4fgmpanel.4fgmonitor.com
# This var isn't set from the repo — it must also be set directly in the Railway
# service's environment for the deployed backend to actually allow these origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3010

# Database (same Supabase Postgres instance used by gas-monitor-web / gas-monitor-admin today)
DATABASE_URL=
DIRECT_URL=

# Consumer/vendor auth (bearer access + refresh tokens)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin auth (cookie session) — separate scheme/secret from the above, kept as-is
ADMIN_JWT_SECRET=
ADMIN_SESSION_EXPIRES_IN=12h
# Bootstrap super-admin login (env-based, in addition to DB-backed AdminUser accounts)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email (Resend) — used for OTP emails; if unset, OTPs are logged to the console instead
EMAIL_FROM="4FG Smart Gas Monitor <onboarding@resend.dev>"
RESEND_API_KEY=

# Paystack
PAYSTACK_SECRET_KEY=
