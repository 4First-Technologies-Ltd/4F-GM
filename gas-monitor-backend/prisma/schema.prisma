generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CONSUMER
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GasType {
  COOKING
  MEDICAL
  INDUSTRIAL
  BULK
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String
  password         String
  role             Role              @default(CONSUMER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  refreshTokens    RefreshToken[]
  vendorProfile    VendorProfile?
  orders           Order[]           @relation("ConsumerOrders")
  cylinderProfiles CylinderProfile[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model VendorProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String
  businessAddress String
  lat             Float?
  lng             Float?
  phone           String
  status          VendorStatus     @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  documents       VendorDocument[]
  listings        GasListing[]
  orders          Order[]          @relation("VendorOrders")

  @@map("vendor_profiles")
}

model VendorDocument {
  id        String        @id @default(uuid())
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  createdAt DateTime      @default(now())

  @@map("vendor_documents")
}

model GasListing {
  id            String        @id @default(uuid())
  vendorId      String
  vendor        VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  gasType       GasType
  customName    String?
  pricePerKg    Float
  cylinderSizes String[]
  otherSizes    String?
  inStock       Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        Order[]

  @@map("gas_listings")
}

model CylinderProfile {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  sizeKg          Float
  customSizeLabel String?
  imageKey        String   @default("12.5kg")
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("cylinder_profiles")
}

model Order {
  id              String         @id @default(uuid())
  consumerId      String
  consumer        User           @relation("ConsumerOrders", fields: [consumerId], references: [id])
  vendorId        String?
  vendor          VendorProfile? @relation("VendorOrders", fields: [vendorId], references: [id])
  listingId       String?
  listing         GasListing?    @relation(fields: [listingId], references: [id])
  supplierName    String?
  cylinderSize    String
  quantity        Int
  totalAmount     Float
  deliveryAddress String
  status          OrderStatus    @default(PENDING)
  paystackRef     String?        @unique
  paystackStatus  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("orders")
}
